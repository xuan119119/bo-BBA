<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    tools:context=".ui.YouboFragment">

    <!-- 顶部：左右图标 + 中间“关注 / 精选 / 附近” Tab，与好看页保持一致 -->
    <RelativeLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@android:color/white">

        <!-- 左侧日历图标（尽量接近示意图样式） -->
        <ImageView
            android:id="@+id/ivLeftAction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_calendar_outline"
            android:clickable="true"
            android:focusable="true" />

        <!-- 右侧“扫描/全屏”图标 -->
        <ImageView
            android:id="@+id/ivRightAction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_scan_outline"
            android:clickable="true"
            android:focusable="true" />

        <!-- 中间的“关注 精选 附近” -->
        <LinearLayout
            android:id="@+id/layoutTabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:orientation="horizontal">

            <!-- 关注 -->
            <LinearLayout
                android:id="@+id/tabFollow"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvFollow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关注"
                    android:textSize="14sp"
                    android:textColor="#808080" />

                <View
                    android:id="@+id/indicatorFollow"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 精选（默认选中） -->
            <LinearLayout
                android:id="@+id/tabFeatured"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvFeatured"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精选"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <View
                    android:id="@+id/indicatorFeatured"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A" />
            </LinearLayout>

            <!-- 附近 -->
            <LinearLayout
                android:id="@+id/tabNearby"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvNearby"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="附近"
                    android:textSize="14sp"
                    android:textColor="#808080" />

                <View
                    android:id="@+id/indicatorNearby"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>

    <!-- 内容区域：承载有播三个子 Fragment -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 保留一个隐藏 TextView 与 ViewModel 绑定 -->
    <TextView
        android:id="@+id/tvContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
