<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    tools:context=".ui.YouboFragment">

    <!-- 顶部：左右图标 + 中间“关注 / 精选 / 附近” Tab，与好看页保持一致 -->
    <RelativeLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@android:color/white">

        <!-- 左侧日历图标（尽量接近示意图样式） -->
        <ImageView
            android:id="@+id/ivLeftAction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_calendar_outline"
            android:clickable="true"
            android:focusable="true" />

        <!-- 右侧“扫描/全屏”图标 -->
        <ImageView
            android:id="@+id/ivRightAction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_scan_outline"
            android:clickable="true"
            android:focusable="true" />

        <!-- 中间的“关注 精选 附近” -->
        <LinearLayout
            android:id="@+id/layoutTabs"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:orientation="horizontal">

            <!-- 关注 -->
            <LinearLayout
                android:id="@+id/tabFollow"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvFollow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关注"
                    android:textSize="14sp"
                    android:textColor="#808080" />

                <View
                    android:id="@+id/indicatorFollow"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 精选（默认选中） -->
            <LinearLayout
                android:id="@+id/tabFeatured"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvFeatured"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="精选"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <View
                    android:id="@+id/indicatorFeatured"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A" />
            </LinearLayout>

            <!-- 附近 -->
            <LinearLayout
                android:id="@+id/tabNearby"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvNearby"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="附近"
                    android:textSize="14sp"
                    android:textColor="#808080" />

                <View
                    android:id="@+id/indicatorNearby"
                    android:layout_width="20dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="#FFB26A"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

     <!-- 顶部搜索栏（优化样式） -->
    <LinearLayout
        android:layout_marginLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 搜索输入区域 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search_gray" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="搜索直播间、商品、短视频"
                android:textSize="13sp"
                android:textColor="#333333"
                android:textColorHint="#B0B0B0"
                android:paddingStart="8dp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <TextView
                android:id="@+id/btnSearch"
                android:layout_width="72dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_search_button"
                android:text="搜索"
                android:textColor="@color/white"
                android:gravity="center"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 右侧购物车图标 -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_cart_outline" />
    </LinearLayout>

    <!-- TODO: 下方可放精选内容列表 -->

    <!-- 内容区域：承载有播三个子 Fragment -->
    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


</LinearLayout>
