<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav_container"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/bottom_nav_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:id="@+id/nav_live"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_live"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_live" />
        <TextView
            android:id="@+id/tv_nav_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="直播"
            android:textColor="@color/bottom_nav_item_selected"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_goods"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_goods"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_goods" />
        <TextView
            android:id="@+id/tv_nav_goods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="好货"
            android:textColor="@color/bottom_nav_item"
            android:textSize="10sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/nav_center_plus"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">
        <View
            android:layout_width="48dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_center_plus_button" />
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:clickable="false"
            android:contentDescription="@null"
            android:focusable="false"
            android:src="@drawable/ic_center_plus" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/nav_message"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <FrameLayout
            android:layout_width="24dp"
            android:layout_height="24dp">
            <ImageView
                android:id="@+id/iv_nav_message"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_message" />
            <View
                android:id="@+id/badge_message"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_badge_dot"
                android:visibility="visible" />
        </FrameLayout>
        <TextView
            android:id="@+id/tv_nav_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="消息"
            android:textColor="@color/bottom_nav_item"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_mine"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_nav_mine"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_mine_smiley" />
        <TextView
            android:id="@+id/tv_nav_mine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="我的"
            android:textColor="@color/bottom_nav_item"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
